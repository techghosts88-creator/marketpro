# Copy this file to .env.local and fill in your Supabase project's values
# (Project Settings > API in the Supabase dashboard).
#
# If these are left unset, MarketPro runs in local demo mode automatically:
# built-in demo accounts, data saved to the browser only. No setup required.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ---- Used by Prisma only (schema management / migrations, run from your
# machine or CI — never shipped to the browser) ----
# Get both from: Supabase Dashboard > Project Settings > Database > Connection string
#   DATABASE_URL -> "Transaction" pooler connection, port 6543 (used by Prisma Client at runtime)
#   DIRECT_URL   -> "Session" / direct connection, port 5432 (used for migrations)
DATABASE_URL=
DIRECT_URL=
