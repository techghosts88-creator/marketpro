# Copy this file to .env.local for local development.
#
# If VITE_API_URL is left unset, MarketPro runs in local demo mode
# automatically: built-in demo accounts, data saved to the browser only.
# No setup required.
#
# Set it to your deployed (or local) backend URL to use real accounts and
# a real database instead. The backend itself lives in /server and has its
# own .env.example — see server/.env.example and README.md.

VITE_API_URL=
