# Copy to .env for local development.

# Get both from: Supabase Dashboard > Project Settings > Database > Connection string
#   DATABASE_URL -> "Transaction" pooler connection, port 6543
#   DIRECT_URL   -> "Session" / direct connection, port 5432 (used by migrations)
DATABASE_URL=
DIRECT_URL=

# Any long random string. Generate one with: openssl rand -base64 32
JWT_SECRET=

# The username that automatically becomes super admin on register/login/me.
# Register (or already have) an account with exactly this username to get
# admin access — no manual database edit needed.
SUPER_ADMIN_USERNAME=

# Only used by `npm run seed:admin` (a one-off script, not the running
# server): creates the super admin account directly in the database, or
# resets its password if it already exists. Leave unset to have the script
# generate and print a random password instead.
SUPER_ADMIN_PASSWORD=

# Powers the real AI voice-command understanding (src/routes/voice.js).
# Get one at https://console.anthropic.com. Without it, voice commands fall
# back to basic pattern matching on the frontend (less flexible, but still
# works — see src/App.jsx's parseVoiceCommand).
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5

# Exact URL of the deployed frontend (no trailing slash), comma-separated if
# you need more than one (e.g. local dev + production).
# Example: https://marketpro-frontend.onrender.com,http://localhost:5173
CORS_ORIGIN=

PORT=4000
